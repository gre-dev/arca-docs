{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Mint Starter Kit",
  "colors": {
    "primary": "#3A72F2",
    "light": "#3A72F2",
    "dark": "#3A72F2"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Knowledge base",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "getting-started/introduction",
              "getting-started/concepts",
              "getting-started/download"
            ]
          },
          {
            "group": "Account",
            "pages": [
              "account/profile",
              "account/notifications",
              "account/preferences",
              "account/points"
            ]
          },
          {
            "group": "Tasks",
            "pages": [
              "tasks/create",
              "tasks/edit",
              "tasks/assign",
              "tasks/select",
              "tasks/subtasks",
              "tasks/editor",
              "tasks/attachments",
              "tasks/comments-and-reactions",
              "tasks/dependencies",
              "tasks/move-and-duplicate",
              "tasks/recurring-tasks"
            ]
          },
          {
            "group": "AI features",
            "pages": ["ai-features/editor-actions"]
          },
          {
            "group": "Lists",
            "pages": ["lists/list-settings"]
          },
          {
            "group": "Views",
            "pages": [
              "views/overview",
              "views/create",
              "views/table",
              "views/calendar",
              "views/timeline"
            ]
          },
          {
            "group": "Analytics",
            "pages": ["analytics/dashboards", "analytics/insights"]
          },
          {
            "group": "Administration",
            "pages": [
              "administration/workspaces",
              "administration/labels",
              "administration/statuses",
              "administration/folders",
              "administration/billing",
              "administration/members-and-roles",
              "administration/invite-members",
              "administration/import",
              "administration/export"
            ]
          },
          {
            "group": "General features",
            "pages": [
              "general-features/search",
              "general-features/sidebar-customization",
              "general-features/keyboard-shortcuts",
              "general-features/member-profiles"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Arca Website",
          "href": "https://getarca.app/",
          "icon": "globe"
        },
        {
          "anchor": "Download Arca",
          "href": "https://getarca.app/download",
          "icon": "download"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:info@getarca.app"
      }
    ]
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "cursor"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  }
}
